<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <%- include('templates/nav.ejs') %>
    <!-- <%- include('templates/alert.ejs') %> -->
    <form action="" method="post" class="auth-div">
        <p style="text-align: center; font-size: 1.5em;">Login</p>
        <input type="text" class="auth-input" placeholder="email" name="email" required>
        <input type="password" class="auth-input" placeholder="password" name="password" required>
        <button class="auth-button">Confirm</button>
        <a href="#forgot" style="color: rgb(198, 198, 198); font-size: 0.8em; margin-top: 3em;">forgot password</a>
        <a href="/signup" style="color: rgb(198, 198, 198); font-size: 0.8em; margin-top: 1em;">sign up</a>
    </form>
</body>
</html>