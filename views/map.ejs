    let directionsController = null
    const el = document.createElement('div');
    el.className = 'marker';
    let directionsmarker = new mapboxgl.Marker(el, {color: "red"})
    function getDirections(endLng, endLat, id) {
        if(navigator.geolocation) {
            if(directionsController) {
                directionsController.abort()
            }
            directionsController = new AbortController()
            const signal = directionsController.signal
            navigator.geolocation.getCurrentPosition(async function(position) {
                console.log(position)
                document.getElementById("directionsAccuracy").innerText = parseInt(position.coords.accuracy)
                let accessToken = "<%= mapboxtoken %>"
                let directionsUrl = `https://api.mapbox.com/directions/v5/mapbox/cycling/${position.coords.longitude},${position.coords.latitude};${endLng},${endLat}?geometries=geojson&access_token=${accessToken}`
                await fetch(directionsUrl, {signal: signal})
                .then(async res => {
                    let json = await res.json()
                    console.log(json)
                    if (map.getSource("route")) {
                        map.getSource("route").setData(json.routes[0].geometry)
                        console.log(json.routes[0].distance)
                        document.getElementById("directionsDistance").innerText = parseInt(json.routes[0].distance)
                        // hideDetails(id)
                        popup.remove()
                        hideModal(currentOpenModal)
                    } else {
                        map.addLayer({
                            id: 'route',
                            type: 'line',
                            source: {
                                type: 'geojson',
                                data: {
                                    type: "Feature",
                                    properties: {},
                                    geometry: json.routes[0].geometry
                                }
                            },
                            layout: {
                                'line-join': 'round',
                                'line-cap': 'round'
                            },
                            paint: {
                                'line-color': "#37ff00",
                                'line-width': 4,
                                'line-opacity': 1
                            }
                        })
                        popup.remove()
                        hideModal(currentOpenModal)
                        map.easeTo({
                            center: [position.coords.longitude, position.coords.latitude],
                            zoom: 13
                        })
                    }
                    directionsmarker.setLngLat([position.coords.longitude, position.coords.latitude]).addTo(map)
                })
                .catch(error => {
                    console.log(error)
                })
            }, function(error) {
                // window.alert("Cannot get user Location")
                console.log(error)
                addNewAlert("ERROR", "Cannot get user location")
            }, {
                enableHighAccuracy: true,
                timeout: 10000,
                maximumAge: 0
            })
        } 
    }

