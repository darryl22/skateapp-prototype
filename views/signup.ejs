<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <%- include('templates/nav.ejs') %>
    <%- include('templates/alert.ejs') %>
    <%- include('templates/theme.ejs') %>
    <form action="" method="post" class="auth-div" id="submitForm">
        <p style="text-align: center; font-size: 1.5em;">Sign up</p>
        <input type="text" class="auth-input" placeholder="username" name="username" id="username" required>
        <input type="text" class="auth-input" placeholder="email" name="email" id="email" required>
        <input type="password" class="auth-input" placeholder="password" name="password" id="password" required>
        <input type="password" class="auth-input" placeholder="confirm password" name="confirmpassword" id="confirmpassword" required>
        <button class="auth-button">Confirm</button>
        <a href="/login" style="color: rgb(198, 198, 198); font-size: 0.8em; margin-top: 3em;">Login</a>
    </form>
</body>
<script>
    document.getElementById("submitForm").addEventListener("submit", async function(e) {
        e.preventDefault()
        await fetch("/signup", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({
                username: document.getElementById("username").value,
                email: document.getElementById("email").value,
                password: document.getElementById("password").value,
                confirmpassword: document.getElementById("confirmpassword").value,
            })
        })
        .then(async res => {
            let resData = await res.json()
            if (resData.status === "SUCCESS") {
                addNewAlert(res.status, res.message)
                setTimeout(() => {
                    if (res.status === "SUCCESS") {
                        window.location.replace(`/verify`)
                    }
                }, 2000)
            } else {
                addNewAlert(res.status, res.message)
            }
        })
        .catch(error => {
            addNewAlert("ERROR", "Error with signup")
        })
    })
</script>
</html>