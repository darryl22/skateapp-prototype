    async function getDirections(startLng, startLat, endLng, endLat) {
        if (directionsController) {
            directionsController.abort()
        }
        directionsController = new AbortController()
        const signal = directionsController.signal
        console.log(startLng, startLat, endLng, endLat)
        let accessToken = "<%= mapboxtoken %>"
        // console.log(position.coords.latitude)
        let directionsUrl = `https://api.mapbox.com/directions/v5/mapbox/${routeType}/${startLng},${startLat};${endLng},${endLat}?geometries=geojson&access_token=${accessToken}`
        await fetch(directionsUrl, {signal: signal})
        .then(async res => {
            let json = await res.json()
            console.log(json)
            popup.remove()
            if (map.getSource("routeSource")) {
                map.getSource("routeSource").setData(json.routes[0].geometry)
                console.log(json.routes[0].distance)
                hideModal(currentOpenModal)
            } else {
                map.addSource('routeSource', {
                    type: 'geojson',
                    data: {
                        type: "Feature",
                        properties: {},
                        geometry: json.routes[0].geometry
                    }
                })
                map.addLayer({
                    id: 'routeLayer',
                    type: 'line',
                    source: 'routeSource',
                    layout: {
                        'line-join': 'round',
                        'line-cap': 'round'
                    },
                    paint: {
                        'line-color': routeColor,
                        'line-width': 4,
                        'line-opacity': 1
                    }
                })
                let visible = map.getLayoutProperty("routeLayer", "visibility")
                if (!visible) {
                    map.setLayoutProperty("routeLayer", "visibility", "visible")
                }
                hideModal(currentOpenModal)
            }
            document.getElementById("directionsDistance").innerText = parseInt(json.routes[0].distance)
            map.easeTo({
                center: [startLng, startLat],
                zoom: 13,
                duration: 500
            })
        })
        .catch(error => {
            console.log(error)
        })
    }
    map.on('load', () => {
        map.addControl(geoLoc);
        for (let x = 0; x < categoryEntries.length; x++) {
            let pointColor = ""
            if (categoryEntries[x][0] === "stairs") {
                pointColor = "green"
                document.getElementById(`typeFilter-stairs`).innerText = categoryEntries[x][1].length
            } else if (categoryEntries[x][0] === "rail") {
                pointColor = "blue"
                document.getElementById(`typeFilter-rail`).innerText = categoryEntries[x][1].length
            } else if (categoryEntries[x][0] === "park") {
                pointColor = "purple"
                document.getElementById(`typeFilter-park`).innerText = categoryEntries[x][1].length
            } else if (categoryEntries[x][0] === "ledge") {
                pointColor = "red"
                document.getElementById(`typeFilter-ledge`).innerText = categoryEntries[x][1].length
            } else {
                pointColor = "gray"
                document.getElementById(`typeFilter-other`).innerText = categoryEntries[x][1].length
            }
            map.addSource(`spotsSource${categoryEntries[x][0]}`, {
                'type': 'geojson',
                'data': {
                    'type': 'FeatureCollection',
                    'features': categoryEntries[x][1]
                },
                // cluster: true,
                // clusterMaxZoom: 11,
                // clusterRadius: 20
                // 'dynamic': true
            })

            map.addLayer({
                'id': `spotsLayer${categoryEntries[x][0]}`,
                'type': 'circle',
                'source': `spotsSource${categoryEntries[x][0]}`,
                'paint': {
                    'circle-color': pointColor,
                    'circle-radius': 8,
                    'circle-stroke-width': 3,
                    'circle-stroke-color': '#ffffff'
                }
            })

            map.on("click", `spotsLayer${categoryEntries[x][0]}`, (e) => {
                map.getCanvas().style.cursor = "pointer"
                // console.log(e.features[0].properties)
                const coordinates = e.features[0].geometry.coordinates.slice()
                const spotId = e.features[0].properties.spotId
                const spotType = e.features[0].properties.spotType
                // const description = popupHtmlList[`spot-${spotId}`]
                let currentData = spotDetailsMap.get(`spot-${spotId}`)
                let description = setPopupHtml(spotId)
                popup.setLngLat(coordinates).setHTML(description).addTo(map);
                let spotCarousel = document.getElementById(`spotDetailsModal${spotId}`).querySelectorAll(".swiper-wrapper")[0]
                if (spotCarousel.getAttribute("data-loaded") === "false") {
                    loadSpotImages(spotId, "all")
                }
                map.easeTo({
                    center: [coordinates[0], (coordinates[1] - 0.023)],
                    zoom: 13,
                    duration: 500
                })
            })
            map.on("mouseover", `spotsLayer${categoryEntries[x][0]}`, e => {
                map.getCanvas().style.cursor = "pointer"
            })
            map.on('mouseleave', `spotsLayer${categoryEntries[x][0]}`, () => {
                map.getCanvas().style.cursor = '';
            });
        }
        document.getElementById(`typeFilter-all`).innerText = spotsData.length
        getOneSpot('spot')
        for (let x = 0; x < spotsData.length; x++) {
            document.getElementById(`getDirections${spotsData[x]._id}`).addEventListener("click", async function() {
                if (map.getSource("routeSource")) {
                    console.log("reset directions")
                    map.removeLayer("routeLayer")
                    map.removeSource("routeSource")
                }
                let endLng = this.getAttribute("data-lng")
                let endLat = this.getAttribute("data-lat")
                spotDirectionCoordinates = [endLng, endLat]
                let id = this.getAttribute("data-id")
                // let startLng = manualDirectionsCoordinates[0]
                // let startLat = manualDirectionsCoordinates[1]
                document.getElementById("spinnerContainer").style.display = "block"
                await userPositionAsync({enableHighAccuracy: true})
                .then(async position => {
                    await getDirections(position.coords.longitude, position.coords.latitude, endLng, endLat)
                    document.getElementById("spinnerContainer").style.display = "none"
                    geoLoc.trigger()
                    document.getElementById("directionsAccuracy").innerText = parseInt(position.coords.accuracy)
                })
                .catch(error => {
                    document.getElementById("spinnerContainer").style.display = "none"
                    console.log("geoloc error", error)
                    let confirmRecalculateDirections = document.getElementById("confirmRecalculateDirections")
                    confirmRecalculateDirections.classList.remove("hidden")
                    manualDirectionsSetMarker.setLngLat(manualDirectionsCoordinates).addTo(map)
                    map.easeTo({
                        center: manualDirectionsCoordinates,
                        zoom: 14,
                        duration: 500
                    })
                    hideModal(currentOpenModal)
                    popup.remove()
                    addNewAlert("ERROR", `Error getting user location, move red marker to start position or try <a href="https://www.google.com/maps/search/?api=1&query=${endLat},${endLng}">view on maps</a>`)
                    // document.getElementById("recalculateDirections").classList.remove("hidden")
                })
                openDirectionsDetails()
            })
        }
    })

    function handleSpotFilters() {
        let typeFilter = document.getElementById("typeFilter")
        let sortByFilter = document.getElementById("sortByFilter")
        let yourFavouritesCheck = document.getElementById("yourFavouritesCheck")
        let savedSpotsCheck = document.getElementById("savedSpotsCheck")

        for (x of categoryEntries) {
            if (x[0] === typeFilter.value || typeFilter.value === "all") {
                map.setLayoutProperty(`spotsLayer${x[0]}`, "visibility", "visible")
            } else {
                map.setLayoutProperty(`spotsLayer${x[0]}`, "visibility", "none")
            }
        }
        hideModal(currentOpenModal)
    }

    const searchResult = document.getElementById("search-js")
    searchResult.onload = function () {
        const searchBox = document.querySelector('mapbox-search-box')
        searchBox.options = {
            language: 'en',
            // country: 'KE',
            proximity: "36.8219, -1.2921"
            // types: "district, place, city, street, address, poi"
        }

        searchBox.addEventListener('retrieve', e => {
            let searchResultCoordinates = e.detail.features[0].geometry.coordinates
            console.log(searchResultCoordinates)
            map.easeTo({
                center: searchResultCoordinates,
                zoom: 13
            })

            addSpotMarker.setLngLat(searchResultCoordinates).addTo(map)
            markerCoordinates = searchResultCoordinates
        })
    }

    const addSpotMarker = new mapboxgl.Marker({color: "red", draggable: true})
    // addSpotMarker.setRotation(45)
    let markerCoordinates = []
    let longitude = document.getElementById("longitude")
    let latitude = document.getElementById("latitude")
    addSpotMarker.on('dragend', function(e) {
        let lngLat = e.target.getLngLat()
        markerCoordinates = [lngLat.lng, lngLat.lat]
        longitude.value = lngLat.lng
        latitude.value = lngLat.lat
        console.log(markerCoordinates)
        map.easeTo({
            center: markerCoordinates,
            zoom: 13,
            duration: 500
        })
    })

    const addNewSpotButton = document.getElementById("addNewSpotButton")
    const cancelNewSpotButton = document.getElementById("cancelNewSpotButton")
    const addSpotForm = document.getElementById("addSpotForm")
    const spotInformation = document.getElementById("spotInformation")

    addNewSpotButton.addEventListener('click', function() {
        // hideMenu()
        hideModal(currentOpenModal)
        popup.remove()
        addSpotForm.style.display = "block"
        // spotInformation.style.display = "none"
        // addNewSpotButton.style.display = "none"

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                console.log(position.coords.latitude, position.coords.longitude, position)
                markerCoordinates = [position.coords.longitude, position.coords.latitude]
                longitude.value = position.coords.longitude
                latitude.value = position.coords.latitude
                map.easeTo({
                    center: [position.coords.longitude, position.coords.latitude],
                    zoom: 13,
                    duration: 500
                })
                addSpotMarker.setLngLat([position.coords.longitude, position.coords.latitude]).addTo(map)
            }, function() {
                addNewAlert("ERROR", "Could not get current user position, drag red marker to spot location.")
                map.easeTo({
                    center: [36.8219, -1.2921],
                    zoom: 13,
                    duration: 500
                })
                addSpotMarker.setLngLat([36.8219, -1.2921]).addTo(map)
            })
        } else {
            addNewAlert("ERROR", "Could not get current user position, drag red marker to spot location.")
            map.easeTo({
                center: [36.8219, -1.2921],
                zoom: 13,
                duration: 500
            })
            addSpotMarker.setLngLat([36.8219, -1.2921]).addTo(map)
        }
    })

    cancelNewSpotButton.addEventListener('click', function() {
        addSpotForm.style.display = "none"
        addSpotMarker.remove()

        map.easeTo({
            center: [36.8219, -1.2921],
            zoom: 10
        })
    })

    function filesToBase64(img) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader
            reader.onload = () => resolve(reader.result)
            reader.onerror = reject
            reader.readAsDataURL(img)
        })
    }

    let editUploadImagesDiv = document.getElementById("editUploadImagesDiv")
    let clearUploadSelections = document.getElementById("clearUploadSelections")
    let spotImageList = new Map()
    let sizeInMB = 0
    let selectedCount = 0
    document.getElementById("spotImages").addEventListener("change", async function() {
        let images = document.getElementById("spotImages")
        let totalSize = 0
        let imageNodesList = ''
        if (images.files.length > 10) {
            addNewAlert("ERROR", "Up to 10 pictures can be uploaded")
            this.value = null
            return
        }
        document.getElementById("modifyUploadImages").classList.remove("hidden")
        for (let x = 0; x < images.files.length; x++) {
            // console.log(images.files[x])
            const compressedImage = await imageConversion.compressAccurately(images.files[x], 400)
            await filesToBase64(compressedImage)
            .then(res => {
                totalSize = totalSize + compressedImage.size
                let imageNode = `<div class="edit-pictures-item" style="background-image: url('${res}');" data-picture-index="${x}">
                    <div class="edit-pictures-check hide-check">
                        <p style="margin: 0;">X</p>
                    </div>
                    <div class="edit-check-circle"></div>
                </div>`
                imageNodesList = imageNodesList + imageNode
                spotImageList.set(`image-${x}`, res)
            })
        }
        sizeInMB = totalSize / 1048576
        if (sizeInMB > 10) {
            document.getElementById("fileSizeSpan").style.color = "red"
        } else {
            document.getElementById("fileSizeSpan").style.color = "green"
            editUploadImagesDiv.replaceChildren()
            editUploadImagesDiv.insertAdjacentHTML("beforeend", imageNodesList)
            document.querySelectorAll(".edit-pictures-item").forEach(elm => {
                let isDragging = false
                elm.addEventListener("click", function() {
                    if (isDragging) {
                        return
                    }
                    let index = parseInt(elm.getAttribute("data-picture-index"))
                    let check = elm.querySelectorAll(".edit-pictures-check")[0]
                    check.classList.toggle("hide-check")
                    console.log("toggled index", index)
                    let image = spotImageList.get(`image-${index}`)
                    selectedCount = 0
                    editUploadImagesDiv.querySelectorAll(".edit-pictures-item").forEach(item => {
                        if (!item.querySelectorAll(".edit-pictures-check")[0].classList.contains("hide-check")) {
                            ++selectedCount
                        }
                    })
                    console.log(selectedCount)
                    if (selectedCount === 0) {
                        clearUploadSelections.classList.add("hidden")
                    } else {
                        clearUploadSelections.classList.remove("hidden")
                    }
                })

                elm.addEventListener("pointerdown", function(e) {
                    e.preventDefault()
                    if (navigator.maxTouchPoints > 0) {
                        return
                    }
                        elm.style.touchAction = "none"
                    let initX = e.clientX
                    let initY = e.clientY
                    isDragging = false
                    let initIndex = parseInt(elm.getAttribute("data-picture-index"))
                    let draggingElm = e.target
                    let image = spotImageList.get(`image-${initIndex}`)
                    let dragImagePlaceholder = document.querySelector(".drag-image-position")
                    dragImagePlaceholder.style.display = "block"
                    dragImagePlaceholder.style.backgroundImage = `${elm.style.backgroundImage}`

                    function dragEvent(drag) {
                        dragImagePlaceholder.style.top = `${drag.clientY - 50}px`
                        dragImagePlaceholder.style.left = `${drag.clientX - 50}px`
                    }

                    function hoverStart(hover) {
                        if (hover.target.classList.contains("edit-pictures-item")) {
                            hover.target.classList.add("edit-pictures-item-draghover")
                        }
                    }

                    function hoverEnd(hover) {
                        if (hover.target.classList.contains("edit-pictures-item")) {
                            hover.target.classList.remove("edit-pictures-item-draghover")
                        }
                    }

                    function stopDrag(stop) {
                        if (Math.abs(stop.clientX - initX) > 10 || Math.abs(stop.clientY - initY) > 10) {
                            isDragging = true
                            if (stop.target.classList.contains("edit-pictures-item")) {
                                stop.target.classList.remove("edit-pictures-item-draghover")
                                if (stop.target !== draggingElm) {
                                    console.log("swap images")
                                    let dropIndex = parseInt(stop.target.getAttribute("data-picture-index"))
                                    let dropImage = spotImageList.get(`image-${dropIndex}`)
                                    let tempBg = draggingElm.style.backgroundImage
                                    draggingElm.style.backgroundImage = stop.target.style.backgroundImage
                                    stop.target.style.backgroundImage = tempBg
                                    spotImageList.set(`image-${initIndex}`, dropImage)
                                    spotImageList.set(`image-${dropIndex}`, image)
                                }
                            }
                        }
                        dragImagePlaceholder.style.display = "none"
                        dragImagePlaceholder.style.top = "-100%"
                        dragImagePlaceholder.style.left = "-100%"
                        document.removeEventListener("pointermove", dragEvent)
                        document.removeEventListener("pointerover", hoverStart)
                        document.removeEventListener("pointerout", hoverEnd)
                        document.removeEventListener("pointerup", stopDrag)
                    }
                    document.addEventListener("pointermove", dragEvent)
                    document.addEventListener("pointerover", hoverStart)
                    document.addEventListener("pointerout", hoverEnd)
                    document.addEventListener("pointerup", stopDrag)
                })

                elm.addEventListener("touchstart", function(e) {
                    // e.preventDefault()
                    elm.style.touchAction = "none"
                    let initX = e.touches[0].clientX
                    let initY = e.touches[0].clientY
                    isDragging = false
                    let initIndex = parseInt(elm.getAttribute("data-picture-index"))
                    let draggingElm = e.target
                    let image = spotImageList.get(`image-${initIndex}`)
                    let dragImagePlaceholder = document.querySelector(".drag-image-position")
                    dragImagePlaceholder.style.display = "block"
                    dragImagePlaceholder.style.backgroundImage = `${elm.style.backgroundImage}`

                    function dragEvent(drag) {
                        dragImagePlaceholder.style.top = `${drag.touches[0].clientY - 50}px`
                        dragImagePlaceholder.style.left = `${drag.touches[0].clientX - 50}px`
                    }

                    function stopDrag(stop) {
                        let endTarget = document.elementFromPoint(stop.changedTouches[0].clientX, stop.changedTouches[0].clientY)
                        if (Math.abs(stop.changedTouches[0].clientX - initX) > 10 || Math.abs(stop.changedTouches[0].clientY - initY) > 10) {
                            isDragging = true
                            if (endTarget.classList.contains("edit-pictures-item")) {
                                endTarget.classList.remove("edit-pictures-item-draghover")
                                if (e.target !== endTarget) {
                                    console.log("swap images")
                                    let dropIndex = parseInt(endTarget.getAttribute("data-picture-index"))
                                    let dropImage = spotImageList.get(`image-${dropIndex}`)
                                    let tempBg = e.target.style.backgroundImage
                                    e.target.style.backgroundImage = endTarget.style.backgroundImage
                                    endTarget.style.backgroundImage = tempBg
                                    spotImageList.set(`image-${initIndex}`, dropImage)
                                    spotImageList.set(`image-${dropIndex}`, image)
                                }
                            }
                        }
                        dragImagePlaceholder.style.display = "none"
                        dragImagePlaceholder.style.top = "-100%"
                        dragImagePlaceholder.style.left = "-100%"
                        document.removeEventListener("touchmove", dragEvent)
                        document.removeEventListener("touchend", stopDrag)
                    }
                    document.addEventListener("touchmove", dragEvent)
                    document.addEventListener("touchend", stopDrag)
                })
            })
            showModal("editUploadImages")
        }
        document.getElementById("fileSizeSpan").innerText = sizeInMB.toFixed(2)
    })

    function clearSelections() {
        editUploadImagesDiv.querySelectorAll(".edit-pictures-item").forEach(elm => {
            let check = elm.querySelectorAll(".edit-pictures-check")[0]
            // check.classList.add("hide-check")
            if (!check.classList.contains("hide-check")) {
                let index = elm.getAttribute("data-picture-index")
                spotImageList.delete(`image-${index}`)
                elm.remove()
            }
        })
        console.log(spotImageList)

        if (spotImageList.size === 0) {
            hideModal(currentOpenModal)
            document.getElementById("spotImages").value = null
            return
        }
    }

    clearUploadSelections.addEventListener("click", clearSelections)

    document.getElementById("addSpotForm").addEventListener("submit", async function(e) {
        e.preventDefault()
        let sendData = []
        let positionIndex = 0
        spotImageList.forEach(item => {
            sendData.push({
                position: positionIndex,
                imageUrl: item
            })
            ++positionIndex
        })
        if (sizeInMB > 10) {
            addNewAlert("ERROR", "Files are too large")
            return
        }
        if (sendData.length === 0) {
            addNewAlert("ERROR", "No files selected")
            return
        }
        document.getElementById("spinnerContainer").style.display = "block"
        await fetch("/addspot", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({
                description: document.getElementById("description").value,
                spottype: document.getElementById("spottype").value,
                lng: markerCoordinates[0],
                lat: markerCoordinates[1],
                spotimages: sendData,
            })
        })
        .then(async res => {
            let resData = await res.json()
            if (resData.status === "SUCCESS") {
                window.location.replace(`/map?spot=${resData.newSpot}`)
            } else if (resData.status === "ERROR") {
                document.getElementById("spinnerContainer").style.display = "none"
            }
        })
        .catch(error => {
            console.log(error)
            document.getElementById("spinnerContainer").style.display = "none"
        })
    })
</script>
</html>