<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <%- include('templates/nav.ejs') %>
    <%- include('templates/alert.ejs') %>
    <%- include('templates/theme.ejs') %>
    <form action="" method="post" class="auth-div" id="loginForm">
        <p style="text-align: center; font-size: 1.5em;">Login</p>
        <input type="text" class="auth-input" placeholder="email" name="email" id="email" required>
        <input type="password" class="auth-input" placeholder="password" name="password" id="password" required>
        <button class="auth-button">Confirm</button>
        <a href="#forgot" style="color: rgb(198, 198, 198); font-size: 0.8em; margin-top: 3em;">forgot password</a>
        <a href="/signup" style="color: rgb(198, 198, 198); font-size: 0.8em; margin-top: 1em;">sign up</a>
    </form>
</body>
<script>
    document.getElementById("loginForm").addEventListener("submit", async function(e) {
        e.preventDefault()
        await fetch("/login", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({
                email: document.getElementById("email").value,
                password: document.getElementById("password").value
            })
        })
        .then(async res => {
            if (!res.ok) {
                addNewAlert("ERROR", res.statusText)
                return
            }
            let resData = await res.json()
            if (resData.status === "SUCCESS") {
                addNewAlert(resData.status, resData.message)
                setTimeout(() => {
                    if (resData.action === "login") {
                        window.location.replace("/profile")
                    } else if (resData.action === "tfa") {
                        window.location.replace("/twoFactorAuth")
                    }
                }, 2000)
            } else {
                addNewAlert(resData.status, resData.message)
            }
        })
        .catch(error => {
            addNewAlert("ERROR", "Error with login")
        })
    })
</script>
</html>