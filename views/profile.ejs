    }

    function hideProfileImageModal() {
        let profileImageModalOuter = document.getElementById("profileImageModalOuter")
        let profileImageModalContainer = document.getElementById("profileImageModalContainer")
        profileImageModalOuter.style.opacity = 0
        profileImageModalContainer.style.transform = "translateY(-20%)"
        profileImageModalOuter.style.pointerEvents = "none"
    }

    document.getElementById("confirmProfileImageUpdate").addEventListener("click", async function() {
        await fetch('/updateProfileImage', {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({
                profileImage: profilePreview
            })
        })
        .then(async res => {
            let resData = await res.json()
            if(resData.status === "SUCCESS") {
                addNewAlert(resData.status, resData.message)
                document.getElementById("profilePicture").style.backgroundImage = `url('${profilePreview}')`
                hideProfileImageModal()
            } else {
                addNewAlert(resData.status, resData.message)
            }
        })
        .catch(error => {
            console.log(error)
            addNewAlert("ERROR", "Error updating image")
        })
    })

    let pillUpdating = false
    document.querySelectorAll(".profile-pill-div").forEach(elm => {
        elm.addEventListener("click", async function() {
            if (pillUpdating) {
                return
            }
            pillUpdating = true
            this.classList.toggle("pill-on")
            let id = this.getAttribute("id")
            let param = this.getAttribute("data-param")
            document.getElementById(`${id}Circle`).classList.toggle("pill-circle-on")
            let pillValue = document.getElementById(`${id}Value`).value
            document.getElementById(`${id}Value`).value = pillValue === "true" ? "false" : "true"
            console.log(document.getElementById(`${id}Value`).value)
            await fetch("/updateProfile", {
                method: "POST",
                headers: {"Content-Type": "application/json"},
                body: JSON.stringify({
                    param: param,
                    value: document.getElementById(`${id}Value`).value
                })
            })
            .then(async res => {
                let resData = await res.json()
                if (resData.status === "SUCCESS") {
                    addNewAlert(resData.status, resData.message)
                    console.log("darkMode", document.getElementById("darkModePillValue").value)
                    if (document.getElementById("darkModePillValue").value === "true") {
                        document.body.classList.add("dark-mode")
                        document.body.classList.remove("light-mode")
                    } else if (document.getElementById("darkModePillValue").value === "false") {
                        document.body.classList.remove("dark-mode")
                        document.body.classList.add("light-mode")
                    } else {
                        document.body.classList.remove("dark-mode")
                        document.body.classList.remove("light-mode")
                    }
                    pillUpdating = false
                } else {
                    addNewAlert(resData.status, resData.message)
                    pillUpdating = false
                }
            })
            .catch(error => {
                addNewAlert("ERROR", "Could not update profile")
                pillUpdating = false
            })
        })
    })
</script>
</html>