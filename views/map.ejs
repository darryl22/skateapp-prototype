<body>
    
    <div class="spinner-container" id="spinnerContainer">
        <img src="/logos/skateboardlight.png" alt="spinner" class="spinner">
    </div>
    <%- include('templates/nav.ejs') %>
    <%- include('templates/alert.ejs') %>
    <%- include('templates/theme.ejs') %>
    <% for(var x = 0; x < spots.length; x++) { %>
    <div class="base-modal spot-details-modal" id="spotDetailsModal<%= spots[x]._id  %>" data-spotid="<%= spots[x]._id  %>">
        <div class="base-modal-inner" id="spotDetailsInner<%= spots[x]._id  %>">
            <img src="./logos/closelight.png" alt="close menu" class="close-menu2 image-invert close-modal" data-toggle-modal="spotDetailsModal<%= spots[x]._id  %>">
            <button class="add-comment" id="addCommentButton<%= spots[x]._id  %>">COMMENT</button>
            <form action="" class="add-comment-form" id="addCommentForm<%= spots[x]._id  %>">
                <textarea name="commentInput" id="commentInput<%= spots[x]._id  %>" class="comment-input" rows="3" placeholder="Add comment" required></textarea>
                <input type="hidden" name="type" id="type<%= spots[x]._id  %>" value="newComment">
                <input type="hidden" name="replyId" id="replyId<%= spots[x]._id  %>" value="">
                <div style="display: flex; gap: 1em;">
                    <button class="add-comment-button" type="submit">SEND</button>
                    <button class="cancel-comment-button" type="button" id="cancelComment<%= spots[x]._id  %>">CANCEL</button>
                </div>
            </form>
            <div class="base-modal-content">
                <div class="swiper" style="height: 60vh;">
                    <div class="swiper-wrapper" data-loaded="false">
                        <div class="swiper-slide" style="display: flex; align-items: center; justify-content: center;">
                            <img src="/logos/skateboardlight.png" alt="spinner" class="spinner">
                        </div>
                    </div>
                    <div class="swiper-pagination"></div>
                    <div class="swiper-button-prev"></div>
                    <div class="swiper-button-next"></div>
                </div>
                <button id="getDirections<%= spots[x]._id  %>" data-lng="<%= spots[x].longitude %>" data-lat="<%= spots[x].latitude %>" data-id="<%= spots[x]._id  %>">Get Directions</button>
                <p id="spotDetailsTitle"><%= spots[x].description  %></p>
                <div style="height: 1px; background-color: gray; margin: 1em 0em;"></div>
                <p id="loadingComments<%= spots[x]._id %>">Loading Comments...</p>
                <div class="comments-div" id="commentsDiv<%= spots[x]._id %>" data-loaded="false">
                    
                </div>
            </div>
        </div>
    </div>
    <script>
        document.getElementById("addCommentButton<%= spots[x]._id  %>").addEventListener("click", function() {
            if ("<%= isLoggedIn %>" === "false") {
                addNewAlert("ERROR", "<a href='/login'>Login</a> required to comment")
                return
            }
            let commentForm = document.getElementById("addCommentForm<%= spots[x]._id  %>")
            let commentButton = document.getElementById("addCommentButton<%= spots[x]._id  %>")
            let type = document.getElementById("type<%= spots[x]._id  %>")
            let input = document.getElementById("commentInput<%= spots[x]._id  %>")
            input.value = ""
            commentForm.style.display = "flex"
            commentButton.style.display = "none"
            type.value = "comment"
        })
        document.getElementById("cancelComment<%= spots[x]._id  %>").addEventListener("click", function() {
            let commentForm = document.getElementById("addCommentForm<%= spots[x]._id  %>")
            let commentButton = document.getElementById("addCommentButton<%= spots[x]._id  %>")
            commentForm.style.display = "none"
            commentButton.style.display = "block"
        })
        document.getElementById("addCommentForm<%= spots[x]._id  %>").addEventListener("submit", function(e) {
            e.preventDefault()
            let commentData = {
                comment: document.getElementById("commentInput<%= spots[x]._id  %>").value,
                type: document.getElementById("type<%= spots[x]._id  %>").value,
                spotId: "<%= spots[x]._id  %>",
                replyId: document.getElementById("replyId<%= spots[x]._id  %>").value
            }
            fetch("/updateComment", {
                method: "POST",
                headers: {
                    // "Accept": "application/json",
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(commentData)
            })
            .then(async res => {
                let result = await res.json()
                console.log("result", result)
                let commentForm = document.getElementById("addCommentForm<%= spots[x]._id  %>")
                let commentButton = document.getElementById("addCommentButton<%= spots[x]._id  %>")
                commentForm.style.display = "none"
                commentButton.style.display = "block"
                if (result.status === "SUCCESS") {
                    if (result.newComment.type === "comment") {
                        loadComments("<%= spots[x]._id  %>", [result.newComment], {newAdded : true})
                        replyListeners("<%= spots[x]._id  %>")

                    } else if(result.newComment.type === "reply"){
                        loadReplies("<%= spots[x]._id  %>", [result.newComment], {newAdded : true})
                        replyListeners("<%= spots[x]._id  %>")

                    }
                } else if (result.status === "ERROR") {
                    addNewAlert(res.status, res.message)
                }
            })
            .catch(error => {
                addNewAlert("ERROR", "Error adding comment")
                console.log(error)
            })
        })
    </script>
    <% } %>

    <div class="map-outer-div">
        <button class="map-inner-sidebar modal-button" data-toggle-modal="menuContent">Options</button>
        <div class="base-modal" id="menuContent">
            <div class="base-modal-inner" id="addSpotDiv">
