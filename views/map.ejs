                                    <option value="ledge" style="color: red;">ledge (<span id="typeFilter-ledge">0</span>)</option>
                                    <option value="rail" style="color: blue;">rail (<span id="typeFilter-rail">0</span>)</option>
                                    <option value="stairs" style="color: green;">stairs (<span id="typeFilter-stairs">0</span>)</option>
                                    <option value="park" style="color: purple;">park (<span id="typeFilter-park">0</span>)</option>
                                    <option value="other" style="color: gray;">other (<span id="typeFilter-other">0</span>)</option>
                                </select>
                            </div>
                            <div style="display: flex; flex-direction: column;">
                                <label for="sortByFilter">Sort By</label>
                                <select name="sortBy" id="sortByFilter" style="padding: 0.3em; margin-top: 0.5em; border: 1px solid gray; border-radius: 4px;" onchange="handleSpotFilters()">
                                    <option value="" selected disabled>select</option>
                                    <option value="popular">Popularity</option>
                                    <option value="recent">most recent</option>
                                </select>
                            </div>
                            
                        </div>
                        <div style="margin-bottom: 1em;">
                            <input type="checkbox" name="yourFavouritesCheck" id="yourFavouritesCheck" onchange="handleSpotFilters()">
                            <label for="yourFavouritesCheck">Your favourites</label>
                        </div>
                        <div>
                            <input type="checkbox" name="savedSpotsCheck" id="savedSpotsCheck" onchange="handleSpotFilters()">
                            <label for="savedSpotsCheck">Saved Spots</label>
                        </div>
                    </div>
                    <p style="margin-top: 2em;">Results</p>
                    <div class="spots-list">
                        <% if (spots.length === 0) {%>
                            <p style="margin: 0;">No Data to show</p>    
                        <%} %>
                        <% for(var x = 0; x < spots.length; x++) { %>
                        <div class="spot-list-item" data-index="<%= x %>" data-id="<%= spots[x]._id %>">
                            <div class="spot-list-item-image" style="background-image: url('/images/carouselimage1.jpg');" id="spotListImage<%= spots[x]._id %>"></div>
                            <div class="spot-list-item-details">
                                <p class="spot-description-short"><%= spots[x].description %></p>
                                <div style="width: 100%;">
                                    <div class="menu-interactions">
                                        <div style="display: flex; gap: 5px">
                                            <div style="display: flex; align-items: center; gap: 0.5em">
                                                <img src="/logos/heart-unfilledlight.png" class="like-button likeButton<%= spots[x]._id %>" data-likeref="" data-isliked="" onclick="likeAction(this, '<%= spots[x]._id %>')"></img>
                                                <p class="likes-count spotLikesCount-<%= spots[x]._id %>"><%= spots[x].likesCount %></p>
                                            </div>
                                            <div style="display: flex; align-items: center; gap: 0.5em">
                                                <img src="/logos/comments-light.png" style="height: 2em;"></img>
                                                <p class="spotCommentsCount-<%= spots[x]._id %>"><%= spots[x].commentsCount%></p>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                                        <button class='base-button modal-button' data-toggle-modal="spotDetailsModal<%= spots[x]._id %>">Details</button>
                                        <div style="width: fit-content;">
                                            <p style="font-size: 0.8em; margin: 0;">Type: <%= spots[x].spottype %></p>
                                            <p style="font-size: 0.8em; margin: 0;">Uploaded by: <%= spots[x].createdBy %></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        <div class="directions-detail-container" id="directionsDetails">
            <img src="/logos/closelight.png" style="height: 1em; cursor: pointer; float: right;" alt="" onclick="closeDirectionsDetails()">
            <p style="clear: both;"><span id="directionsDistance">0</span> meters</p>
            <p>Accuracy: <span id="directionsAccuracy">25</span> meters</p>
            <div class="directions-picker">
                <p style="background-color: blue;" class="directions-picker-item directions-picker-selected" data-profile="driving" data-profile-color="blue">drive</p>
                <p style="background-color: green;" class="directions-picker-item" data-profile="walking" data-profile-color="green">walk</p>
                <p style="background-color: purple;" class="directions-picker-item" data-profile="cycling" data-profile-color="purple">cycle</p>
            </div>
            <button class="base-button hidden" style="margin-top: 1em;" id="recalculateDirections">Recenter</button>
            <button class="base-button hidden" style="margin-top: 1em;" id="confirmRecalculateDirections">Confirm</button>
        </div>
        <div id="map" class="map-div"></div>
        <div class="map-sidebar" id="addSpotForm">
            <button class="cancel-spot-button" id="cancelNewSpotButton">Cancel</button>
            <p>Drag the red marker to spot location(Current Location might be inaccurate)</p>
            <form action="/addspot" method="post" class="addspot-form">
                <input type="hidden" value="0" name="longitude" id="longitude">
                <input type="hidden" value="0" name="latitude" id="latitude">
                <mapbox-search-box access-token="<%= mapboxtoken %>" proximity="0, 0" style="margin-bottom: 1em;"></mapbox-search-box>
                <label for="description" style="margin-bottom: 0.5em;">Description</label>
                <textarea name="description" id="description" style="margin-bottom: 1em; height: 4em; border-radius: 5px; padding: 5px; background-color: rgba(0, 0, 0, 0); color: white;" required></textarea>

                <label for="spottype">Spot Type</label>
                <select name="spottype" id="spottype" style="padding: 0.3em; margin-top: 0.5em; border: 1px solid gray; border-radius: 4px; margin-bottom: 1em;" required>
                    <option value="" selected disabled>select one</option>
                    <option value="rail">rail</option>
                    <option value="stairs">stairs</option>
                    <option value="park">park</option>
                    <option value="ledge">ledge</option>
                    <option value="other">other</option>
                </select>

                <label for="spotImages" style="margin-bottom: 0.5em;">Upload Images</label>
                <input type="file" name="images" id="spotImages" accept="image/png, image/jpeg" multiple required>
                <!-- <input type="file" name="images" id="spotImages" accept="image/png, image/jpeg" multiple> -->
                <p style="font-size: 0.8em; margin-top: 5px;">File size: <span id="fileSizeSpan">0</span> mb</p>
                <button type="button" class="base-button modal-button hidden" data-toggle-modal="editUploadImages" id="modifyUploadImages" style="width: fit-content;">Edit Images</button>

                <button class="spot-confirm" >Confirm</button>
            </form>
        </div>
        <div class="base-modal" id="editUploadImages">
            <div class="base-modal-inner">
                <img src="./logos/closelight.png" alt="close menu" class="close-menu2 image-invert close-modal" data-toggle-modal="editUploadImages">
                <div class="base-modal-content">
                    <div class="edit-pictures-div" id="editUploadImagesDiv"></div>
                    <button class="base-button hidden" style="color: red; border: 1px solid red; margin-top: 1em;" id="clearUploadSelections">Clear</button>
                </div>
            </div>
        </div>
    </div>
    <div class="drag-image-position"></div>
</body>
<div id="spot-container" data-object="<%= JSON.stringify(spots) %>"></div>
<div id="likes-load-container" data-object="<%= JSON.stringify(likes) %>"></div>
<script>
    // const swiper = new Swiper('.swiper', {
    //     direction: 'horizontal',
    //     // slidesPerView: 2,
    //     loop: true,
    //     pagination: {
    //         el: '.swiper-pagination',
    //     },
    //     navigation: {
    //         nextEl: '.swiper-button-next',
    //         prevEl: '.swiper-button-prev',
    //     },
    //     scrollbar: {
    //         el: '.swiper-scrollbar',
    //     },
    // });
    // const swiperF = document.querySelector('.swiper').swiper;
    // let swiper = null

    let dataContainer = document.getElementById('spot-container');
    let likesListContainer = document.getElementById('likes-load-container')
    let spotsData = JSON.parse(dataContainer.getAttribute('data-object'));
    let likesList = JSON.parse(likesListContainer.getAttribute('data-object'))
    let loggedInUserID = "<%= userID %>"
    // let spotsData = JSON.parse('<%- JSON.stringify(spots)%>')
    // let isvisible = null
    let spotsListObserverContainer = document.getElementById("addSpotDiv")
    let spotListItems = document.querySelectorAll(".spot-list-item")
    const spotListCallback = (entries, observer) => {
        entries.forEach(item => {
            console.log(item.isIntersecting)
            console.log(item.target.getAttribute("data-index"))
            let spotId = item.target.getAttribute("data-id")
            if(item.isIntersecting){
                loadSpotImages(spotId, "all")
                observer.unobserve(item.target)
            }
        })
    }

    function shortText(text, length) {
        let newText = text.slice(0, length)
        newText = newText + "..."
        return newText
    }

    document.querySelectorAll(".spot-description-short").forEach(item => {
        let description = item.innerText
        if (description.length > 100) {
            item.innerText = shortText(description, 100)
        }
    })

    let spotsListObserver = new IntersectionObserver(spotListCallback, {
        root: spotsListObserverContainer,
        threshold: 1,
        // trackVisibility: true,
        // delay: 100
    })
    spotListItems.forEach(item => {
        spotsListObserver.observe(item)
    })
    // spotsListObserver.observe(spotListItems[0])

    // async function getUser() {
    //     let userRes = await fetch('/getUser')
    //     .then(res => {
    //         console.log(res)
    //         return res
    //     })
    // }

    let currentOpenModal = null

    function hideModal(id) {
        if (!id) {
            return
        }
        let modalOuter = document.getElementById(`${id}`)
        let modalInner = modalOuter.querySelectorAll(".base-modal-inner")[0]
        modalOuter.style.opacity = "0"
        modalOuter.style.pointerEvents = "none"
        modalInner.style.transform = "translateY(-20px)"
        currentOpenModal = null
    }

    async function showModal(id) {
        let modalOuter = document.getElementById(`${id}`)
        let modalInner = modalOuter.querySelectorAll(".base-modal-inner")[0]
        modalOuter.style.opacity = "1"
        modalOuter.style.pointerEvents = "auto"
        modalInner.style.transform = "translateY(0)"
        currentOpenModal = id
        console.log("open modal")
        // popup.remove()
        if (modalOuter.classList.contains("spot-details-modal")) {
            let spotId = modalOuter.getAttribute("data-spotid")
            let commentsLoaded = modalOuter.querySelectorAll(".comments-div")[0].getAttribute("data-loaded")
            if (commentsLoaded === "false") {
                await fetch(`/loadComments?spotId=${spotId}`, {
                    method: "GET"
                })
                .then(async res => {
                    let resData = await res.json()
                    if (resData.status === "SUCCESS") {
                        loadComments(spotId, resData.comments)
                        loadReplies(spotId, resData.replies)
                        replyListeners(spotId)
                        await loadCommentsInfo(spotId)
                        document.getElementById(`commentsDiv${spotId}`).setAttribute("data-loaded", "true")
                    } else if(resData.status === "ERROR") {
                        addNewAlert(resData.status, resData.message)
                    }
                })
                .catch(error => {
                    console.log(error)
                })
            }
        }
    }

    document.querySelectorAll(".modal-button").forEach(elm => {
        elm.addEventListener("click", function() {
            console.log("open")
            if(currentOpenModal !== null) {
                hideModal(currentOpenModal)
            }
            let id = this.getAttribute("data-toggle-modal")
            showModal(id)
        })
    })

    document.querySelectorAll(".close-modal").forEach(elm => {
        elm.addEventListener("click", function() {
            let id = this.getAttribute("data-toggle-modal")
            hideModal(id)
        })
    })

    document.addEventListener("click", function(e) {
        if (currentOpenModal) {
            let modal = document.getElementById(currentOpenModal).querySelectorAll(".base-modal-inner")[0]
            let alertDiv = document.getElementById("alertDiv")
            if (!modal.contains(e.target) && !e.target.classList.contains("modal-button") && !alertDiv.contains(e.target)) {
                hideModal(currentOpenModal)
            }
        }
    })

    mapboxgl.accessToken = "<%= mapboxtoken %>"
    let darkMap = "<%= darkMap %>"
    const map = new mapboxgl.Map({
        container: 'map',
        style: darkMap === "true" ? 'mapbox://styles/mapbox/dark-v11' : 'mapbox://styles/mapbox/streets-v12',
        center: [36.8219, -1.2921],
        zoom: 10
    })

    // let likeActionController = null
    let pauseLike = false
    async function likeAction(elm, spotID) {
        if (pauseLike) {
            return
        }
        // if (likeActionController) {
        //     likeActionController.abort()
        // }
        if ("<%= isLoggedIn %>" === "false") {
            addNewAlert("ERROR", "<a href='/login'>Login</a> required for interactions")
            return
        }
        pauseLike = true
        // likeActionController = new AbortController()
        // const likeActionSignal = likeActionController.signal
        // let likeButton = this.getElementById(`likeButton${spotID}`)
        let isLiked = elm.getAttribute("data-isliked")
        let likeRef = elm.getAttribute("data-likeref")
        let likesCounter = document.querySelectorAll(`.spotLikesCount-${spotID}`)
        if (isLiked === "true" && likeRef === "None") {
            console.log("cancel like")
            return
        }
        let src = isLiked === "true" ? '/logos/heart-unfilledlight.png' : '/logos/heart-filledlight.png'
        document.querySelectorAll(`.likeButton${spotID}`).forEach(item => {item.setAttribute("src", src)})
        let currentData = spotDetailsMap.get(`spot-${spotID}`)
        await fetch("/updateLiked", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({
                ID: spotID,
                isLiked: isLiked,
                likeRef: likeRef
            }),
            // signal: likeActionSignal
        })
        .then(async res => {
            let resData = await res.json()
            console.log(res)
            pauseLike = false
            if (resData.status === "SUCCESS") {
                document.querySelectorAll(`.likeButton${spotID}`).forEach(item => {
                    item.setAttribute("data-isliked", resData.isLiked)
                    item.setAttribute("data-likeref", resData.likeRef)
                })
                // let likesCount = parseInt(likesCounter[0].innerText)
                let likesCount = currentData.likesCount
                let newLikesCount = resData.isLiked ? `${++likesCount}` : `${--likesCount}`
                likesCounter.forEach(item => item.innerText = newLikesCount)
                spotDetailsMap.set(`spot-${spotID}`, {
                    ...currentData,
                    likeRef: resData.likeRef,
                    likesCount: newLikesCount,
                    isLiked: resData.isLiked,
                })
            }
        })
        .catch(error => {
            pauseLike = false
        })
    }

    let repliesController = null
    function replyListeners(id) {
        if (repliesController) {
            repliesController.abort()
        }
        repliesController = new AbortController()
        const repliesSignal = repliesController.signal
        document.querySelectorAll(".reply-button").forEach(elm => {
            elm.addEventListener("click", function(e) {
                if ("<%= isLoggedIn %>" === "false") {
                    addNewAlert("ERROR", "<a href='/login'>Login</a> required to comment")
                    return
                }
                let spotID = e.target.getAttribute("data-spotid")
                let author = e.target.getAttribute("data-author")
                let replyref = e.target.getAttribute("data-replyref")
                let commentForm = document.getElementById(`addCommentForm${id}`)
                let commentButton = document.getElementById(`addCommentButton${id}`)
                let input = document.getElementById(`commentInput${id}`)
                let replyID = document.getElementById(`replyId${id}`)
                replyID.value = replyref
                commentForm.style.display = "flex"
                commentButton.style.display = "none"
