                e.preventDefault()
                console.log("new images")
                let id = elm.getAttribute("data-id")
                let images = document.getElementById(`addSpotImages-${id}`)
                if ((images.length + selectedImages.get(`spot-${id}`).size) > 10) {
                    addNewAlert("ERROR", "Can't add more than 10 images")
                    images.value = null
                    return
                }
                let totalSize = 0
                let currentPosition = selectedImages.get(`spot-${id}`).size
                let newImages = []
                for (let x = 0; x < images.files.length; x++) {
                    const compressedImage = await imageConversion.compressAccurately(images.files[x], 400)
                    await filesToBase64(compressedImage)
                    .then(res => {
                        newImages.push({
                            position: currentPosition,
                            imageUrl: res,
                            spotId: id
                        })
                    })
                    currentPosition = currentPosition + 1
                    totalSize = totalSize + compressedImage.size
                }
                let sizeInMB = totalSize / 1048576
                if (sizeInMB > 10) {
                    addNewAlert("ERROR", "Files are too large")
                    return
                }
                await fetch('/addSpotImages', {
                    method: "POST",
