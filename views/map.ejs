<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- swiper cdn -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <!-- mapbox dependencies -->
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.6.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.6.0/mapbox-gl.js"></script>

    <!-- mapbox geolocation -->
    <script src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.0/mapbox-gl-geocoder.min.js"></script>

    <!-- for the search bar -->
    <script id="search-js" defer src="https://api.mapbox.com/search-js/v1.1.0/web.js"></script>
    <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.0/mapbox-gl-geocoder.css" type="text/css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
    <style>
        .nav-div{
            box-shadow: none;
            /* border-bottom: none; */
        }

        .swiper {
            width: 100%;
            height: 50vh;
        }

        body{
            overflow: hidden;
        }
    </style>
</head>
<body>
    
    <div class="spinner-container" id="spinnerContainer">
        <img src="/logos/skateboardlight.png" alt="spinner" class="spinner">
    </div>
    <%- include('templates/nav.ejs') %>
    <%- include('templates/alert.ejs') %>
    <div class="map-inner-sidebar-content" id="menuContent">
        <!-- <img src="./logos/closelight.png" alt="close menu" class="close-menu" onclick="hideMenu()"> -->
        <div class="addspot-div" id="addSpotDiv">
            <img src="./logos/closelight.png" alt="close menu" class="close-menu2" onclick="hideMenu()">
            <button class="add-spot-button" id="addNewSpotButton">Add new spot</button>
            <div id="spotInformation" style="margin-top: 2em;">
                <p>Filters</p>
                <div>
                    <div class="map-filters">
                        <div style="display: flex; flex-direction: column;">
                            <label for="">Spot type</label>
                            <select name="typefilter" id="typeFilter" style="padding: 0.3em; margin-top: 0.5em; border: 1px solid gray; border-radius: 4px;" onchange="handleSpotFilters()">
                                <option value="" selected disabled>select</option>
                                <option value="all">all</option>
                                <option value="ledge">ledge</option>
                                <option value="rail">rail</option>
                                <option value="stairs">stairs</option>
                                <option value="park">park</option>
                                <option value="other">other</option>
                            </select>
                        </div>
                        <div style="display: flex; flex-direction: column;">
                            <label for="">Sort By</label>
                            <select name="sortBy" id="sortByFilter" style="padding: 0.3em; margin-top: 0.5em; border: 1px solid gray; border-radius: 4px;" onchange="handleSpotFilters()">
                                <option value="" selected disabled>select</option>
                                <option value="popular">Popularity</option>
                                <option value="recent">most recent</option>
                            </select>
                        </div>
                        
                    </div>
                    <div style="margin-bottom: 1em;">
                        <input type="checkbox" name="yourFavouritesCheck" id="yourFavouritesCheck" onchange="handleSpotFilters()">
                        <label for="yourFavouritesCheck">Your favourites</label>
                    </div>
                    <div>
                        <input type="checkbox" name="savedSpotsCheck" id="savedSpotsCheck" onchange="handleSpotFilters()">
                        <label for="savedSpotsCheck">Saved Spots</label>
                    </div>
                </div>
                <p style="margin-top: 2em;">Results</p>
                <div class="spots-list">
                    <% for(var x = 0; x < spots.length; x++) { %>
                    <div class="spot-list-item">
                        <div class="spot-list-item-image" style="background-image: url('<%= spots[x].spotimages[0] %>');"></div>
                        <div class="spot-list-item-details">
                            <p><%= spots[x].description %></p>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <% for(var x = 0; x < spots.length; x++) { %>
    <div class="spot-details-modal" id="spotDetailsModal<%= spots[x]._id  %>">
        <!-- <img src="./logos/closelight.png" alt="close menu" class="close-menu" onclick="hideDetails('<%= spots[x]._id  %>')"> -->
        <div class="spot-details-modal-inner" id="spotDetailsInner<%= spots[x]._id  %>">
            <img src="./logos/closelight.png" alt="close menu" class="close-menu2" onclick="hideDetails('<%= spots[x]._id  %>')">
            <div class="swiper" style="height: 60vh;">
                <div class="swiper-wrapper">
                    <% for(var y = 0; y < spots[x].spotimages.length; y++) { %>
                    <div class="swiper-slide">
                        <div class="carousel-image" style="background-image: url('<%= spots[x].spotimages[y]  %>'); background-size: contain;"></div>
                    </div>
                    <% } %>
                </div>
                <div class="swiper-pagination"></div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
            </div>
            <p id="spotDetailsTitle"><%= spots[x].description  %></p>
            <button onclick="getDirections('36.8219', '-1.2921', '<%= spots[x].longitude %>', '<%= spots[x].latitude %>', '<%= spots[x]._id  %>')">Get Directions</button>
        </div>
    </div>
    <% } %>

    <div class="map-outer-div">
        <div class="map-inner-sidebar" onclick="showMenu()">
            <!-- <img src="/logos/menu.png" alt="menulogo" class="menu-logo"> -->
            <p style="margin: 0;">OPTIONS</p>
        </div>
        <div id="map" class="map-div"></div>
        <div class="map-sidebar" id="addSpotForm">
            <button class="cancel-spot-button" id="cancelNewSpotButton">Cancel</button>
            <p>Drag the red marker to spot location</p>
            <form action="/addspot" method="post" class="addspot-form">
                <input type="hidden" value="0" name="longitude" id="longitude">
                <input type="hidden" value="0" name="latitude" id="latitude">
                <mapbox-search-box access-token="<%= mapboxtoken %>" proximity="0, 0" style="margin-bottom: 1em;"></mapbox-search-box>
                <!-- <label for="serachArea">Search</label> -->
                <!-- <input type="text" name="searchArea" id="searchArea"> -->
                <label for="description" style="margin-bottom: 0.5em;">Description</label>
                <textarea name="description" id="description" style="margin-bottom: 1em; height: 4em; border-radius: 5px; padding: 5px; background-color: rgba(0, 0, 0, 0); color: white;"></textarea>

                <label for="spottype">Spot Type</label>
                <select name="spottype" id="spottype" style="padding: 0.3em; margin-top: 0.5em; border: 1px solid gray; border-radius: 4px; margin-bottom: 1em;">
                    <option value="" selected disabled>select one</option>
                    <option value="rail">rail</option>
                    <option value="stairs">stairs</option>
                    <option value="park">park</option>
                    <option value="ledge">ledge</option>
                    <option value="other">other</option>
                </select>

                <label for="images" style="margin-bottom: 0.5em;">Upload Images</label>
                <input type="file" name="images" id="spotImages" accept="image/png, image/jpeg" multiple required>
                <!-- <input type="file" name="images" id="spotImages" accept="image/png, image/jpeg" multiple> -->
                <p style="font-size: 0.8em; margin-top: 5px;">File size: <span id="fileSizeSpan">0</span> mb</p>

                <button class="spot-confirm">Confirm</button>
            </form>
        </div>
    </div>
</body>
<div id="spot-container" data-object="<%= JSON.stringify(spots) %>"></div>
<script>
    const swiper = new Swiper('.swiper', {
        direction: 'horizontal',
        // slidesPerView: 2,
        loop: true,
        pagination: {
            el: '.swiper-pagination',
        },
        navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
        },
        scrollbar: {
            el: '.swiper-scrollbar',
        },
    });

    let dataContainer = document.getElementById('spot-container');
    let spotsData = JSON.parse(dataContainer.getAttribute('data-object'));
    // let spotsData = JSON.parse('<%- JSON.stringify(spots)%>')

    function showMenu() {
        let menuContent = document.getElementById("menuContent")
        let addSpotDiv = document.getElementById("addSpotDiv")
        addSpotDiv.style.transform = "translateY(0)"
        // menuContent.style.display = "flex"
        menuContent.style.opacity = "1"
        menuContent.style.pointerEvents = "auto"
        popup.remove()
    }

    function hideMenu() {
        let menuContent = document.getElementById("menuContent")
        // menuContent.style.display = "none"
        menuContent.style.opacity = "0"
        menuContent.style.pointerEvents = "none"
        addSpotDiv.style.transform = "translateY(-20%)"
    }

    function hideDetails(id) {
        let spotDetailsModal = document.getElementById(`spotDetailsModal${id}`)
        let spotDetailsInner = document.getElementById(`spotDetailsInner${id}`)
        // spotDetailsModal.style.display = "none"
        spotDetailsModal.style.opacity = "0"
        spotDetailsInner.style.transform = "translateY(-20%)"
        spotDetailsModal.style.pointerEvents = "none"
    }

    function showSpotDetails(id) {
        let spotDetailsModal = document.getElementById(`spotDetailsModal${id}`)
        let spotDetailsInner = document.getElementById(`spotDetailsInner${id}`)
        // spotDetailsModal.style.display = "flex"
        spotDetailsModal.style.opacity = "1"
        spotDetailsInner.style.transform = "translateY(0)"
        spotDetailsModal.style.pointerEvents = "auto"
        popup.remove()
    }

    mapboxgl.accessToken = "<%= mapboxtoken %>"
    const map = new mapboxgl.Map({
        container: 'map',
        style: 'mapbox://styles/mapbox/dark-v11',
        center: [36.8219, -1.2921],
        zoom: 10
    })
    // map.addControl(new mapboxgl.GeolocateControl({
    //     positionOptions: {
    //         enableHighAccuracy: true
    //     },
    //     trackUserLocation: true,
    //     showUserHeading: true,
    // }));

    let spotPoints = spotsData.map((item, index) => {
        return {
            'type': 'Feature',
            'properties': {
                'description':
                `<div>
                    <p style="font-weight: bold; font-size: 2em; margin-bottom: 10px; margin-top: 0em;">${item.spottype}</p>
                    <img class="spot-details-image" src="${item.spotimages[0]}"></img>
                    <p style="font-size: 1.3em;">${item.description}</p>
                    <p style="font-size: 1.3em; color: var(--lightblue)">Uploaded by: ${item.createdBy}</p>
                    <button class='spot-details-button' onclick="showSpotDetails('${item._id}')">Details</button>
                </div>`
            },
            'geometry': {
                'type': 'Point',
                'coordinates': [item.longitude, item.latitude]
            },
            'spotID': item._id,
            'spotType': item.spottype
        }
    })

    console.log('spot points', spotsData)
    let spotCategories = {
        ledge: [],
        rail: [],
        stairs: [],
        park: [],
        other: [],
    }
    async function getOneSpot(paramName) {
        let searchParams = new URLSearchParams(window.location.search)
        if (searchParams.has(paramName)) {
            let spotID = searchParams.get(paramName)
            let spotResult = await fetch(`/getSpot?spotID=${spotID}`)
            let spotData = await spotResult.json()
            console.log(spotData)
            addNewAlert(spotData.status, spotData.message)
            if(spotData.spot) {
                map.easeTo({
                    center: [spotData.spot.longitude, spotData.spot.latitude],
                    zoom: 13,
                    duration: 500
                })
                for (x of spotPoints) {
                    if (x.spotID === spotID) {
                        console.log(x)
                        popup.setLngLat([spotData.spot.longitude, spotData.spot.latitude]).setHTML(x.properties.description).addTo(map);
                        
                    }
                }
            }
        }
    }

    for (x of spotPoints) {
        if (x.spotType === "ledge") {
            spotCategories.ledge.push(x)
        } else if (x.spotType === "rail") {
            spotCategories.rail.push(x)
        } else if (x.spotType === "stairs") {
            spotCategories.stairs.push(x)
        } else if (x.spotType === "park") {
            spotCategories.park.push(x)
        } else {
            spotCategories.other.push(x)
        }
    }

    let categoryEntries = Object.entries(spotCategories)
    console.log("Cat entries", categoryEntries)
    console.log("screen width", screen.width)

    const popup = new mapboxgl.Popup({maxWidth: "390px"})
    map.on('load', () => {
        for (let x = 0; x < categoryEntries.length; x++) {
            let pointColor = ""
            if (categoryEntries[x][0] === "stairs") {
                pointColor = "green"
            } else if (categoryEntries[x][0] === "rail") {
                pointColor = "blue"
            } else if (categoryEntries[x][0] === "park") {
                pointColor = "purple"
            } else if (categoryEntries[x][0] === "ledge") {
                pointColor = "red"
            } else {
                pointColor = "gray"
            }
            map.addSource(`spotsSource${categoryEntries[x][0]}`, {
                'type': 'geojson',
                'data': {
                    'type': 'FeatureCollection',
                    'features': categoryEntries[x][1]
                }
            })

            map.addLayer({
                'id': `spotsLayer${categoryEntries[x][0]}`,
                'type': 'circle',
                'source': `spotsSource${categoryEntries[x][0]}`,
                'paint': {
                    'circle-color': pointColor,
                    // 'circle-color': categoryEntries[x][0] === "stairs" ? '#021526' : "red",
                    'circle-radius': 8,
                    'circle-stroke-width': 2,
                    'circle-stroke-color': '#ffffff'
                }
            })

            map.on("click", `spotsLayer${categoryEntries[x][0]}`, (e) => {
                map.getCanvas().style.cursor = "pointer"
                const coordinates = e.features[0].geometry.coordinates.slice()
                const description = e.features[0].properties.description
                popup.setLngLat(coordinates).setHTML(description).addTo(map);
                map.easeTo({
                    center: e.features[0].geometry.coordinates.slice(),
                    zoom: 13,
                    duration: 500
                })
                // let getLayer = map.getLayer(`spotsLayer${categoryEntries[x][0]}`, 'id')
                // console.log("Layer property", getLayer)
            })
            map.on("mouseover", `spotsLayer${categoryEntries[x][0]}`, e => {
                map.getCanvas().style.cursor = "pointer"
            })
            map.on('mouseleave', `spotsLayer${categoryEntries[x][0]}`, () => {
                map.getCanvas().style.cursor = '';
            });
        }
        getOneSpot('spot')
    })

    async function getDirections(startLng, startLat, endLng, endLat, id) {
        let accessToken = "<%= mapboxtoken %>"
        console.log(startLng, startLat, endLng, endLat, accessToken)
        let directionsUrl = `https://api.mapbox.com/directions/v5/mapbox/cycling/${startLng},${startLat};${endLng},${endLat}?geometries=geojson&access_token=${accessToken}`
        // let directionsUrl = "https://api.mapbox.com/directions/v5/mapbox/cycling/-84.518641,39.134270;-84.512023,39.102779?geometries=geojson&access_token=pk.eyJ1IjoiZGFycm8yNTQiLCJhIjoiY20wcDM4OW84MDB3aDJuc2JmOXFyYXppNCJ9.UAZYYFCxhyyQ4iOzCIFQgg"
        let request = await fetch(directionsUrl)
        let json = await request.json()
        console.log(json)
        if (map.getSource("route")) {
            map.getSource("route").setData(json.routes[0].geometry)
            hideDetails(id)
        } else {
            map.addLayer({
                id: 'route',
                type: 'line',
                source: {
                    type: 'geojson',
                    data: {
                        type: "Feature",
                        properties: {},
                        geometry: json.routes[0].geometry
                    }
                },
                layout: {
                    'line-join': 'round',
                    'line-cap': 'round'
                },
                paint: {
                    'line-color': "#37ff00",
                    'line-width': 4,
                    'line-opacity': 1
                }
            })
            hideDetails(id)
        }
        map.easeTo({
            center: [startLng, startLat],
            zoom: 13
        })
    }

    function handleSpotFilters() {
        let typeFilter = document.getElementById("typeFilter")
        let sortByFilter = document.getElementById("sortByFilter")
        let yourFavouritesCheck = document.getElementById("yourFavouritesCheck")
        let savedSpotsCheck = document.getElementById("savedSpotsCheck")
        console.log(typeFilter.value, sortByFilter.value, yourFavouritesCheck.checked, savedSpotsCheck.checked)
        // if (typeFilter.value === "ledge") {
        //     map.setLayoutProperty("spotsLayerledge", "visibility", 'none')
        //     // map.setLayoutProperty("spotsLayerledge", "visibility", 'visible')
        // }
        // let paintProperty = map.getPaintProperty('spotsLayerledge', 'source')
        // console.log("Paint property", paintProperty)

        for (x of categoryEntries) {
            if (x[0] === typeFilter.value || typeFilter.value === "all") {
                map.setLayoutProperty(`spotsLayer${x[0]}`, "visibility", "visible")
            } else {
                map.setLayoutProperty(`spotsLayer${x[0]}`, "visibility", "none")
            }
        }
        hideMenu()
        // map.easeTo({
        //     center: [36.8219, -1.2921],
        //     zoom: 10
        // })
    }

    const addSpotMarker = new mapboxgl.Marker({color: "red", draggable: true})
    let markerCoordinates = []
    let longitude = document.getElementById("longitude")
    let latitude = document.getElementById("latitude")
    addSpotMarker.on('dragend', function(e) {
        let lngLat = e.target.getLngLat()
        markerCoordinates = [lngLat.lng, lngLat.lat]
        longitude.value = lngLat.lng
        latitude.value = lngLat.lat
        console.log(markerCoordinates)
    })

    const addNewSpotButton = document.getElementById("addNewSpotButton")
    const cancelNewSpotButton = document.getElementById("cancelNewSpotButton")
    const addSpotForm = document.getElementById("addSpotForm")
    const spotInformation = document.getElementById("spotInformation")

    addNewSpotButton.addEventListener('click', function() {
        hideMenu()
        addSpotForm.style.display = "block"
        // spotInformation.style.display = "none"
        // addNewSpotButton.style.display = "none"

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                console.log(position.coords.latitude, position.coords.longitude)
                markerCoordinates = [position.coords.longitude, position.coords.latitude]
                longitude.value = position.coords.longitude
                latitude.value = position.coords.latitude
                map.easeTo({
                    center: [position.coords.longitude, position.coords.latitude],
                    zoom: 13
                })
                addSpotMarker.setLngLat([position.coords.longitude, position.coords.latitude]).addTo(map)
            })
        }
    })

    const searchResult = document.getElementById("search-js")
    searchResult.onload = function () {
        const searchBox = document.querySelector('mapbox-search-box')
        searchBox.options = {
            language: 'en',
            // country: 'KE',
            proximity: "36.8219, -1.2921"
            // types: "district, place, city, street, address, poi"
        }

        searchBox.addEventListener('retrieve', e => {
            let searchResultCoordinates = e.detail.features[0].geometry.coordinates
            console.log(searchResultCoordinates)
            map.easeTo({
                center: searchResultCoordinates,
                zoom: 13
            })

            addSpotMarker.setLngLat(searchResultCoordinates).addTo(map)
            markerCoordinates = searchResultCoordinates
        })
    }

    cancelNewSpotButton.addEventListener('click', function() {
        addSpotForm.style.display = "none"
        addSpotMarker.remove()

        map.easeTo({
            center: [36.8219, -1.2921],
            zoom: 10
        })
    })

    function filesToBase64(img) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader
            reader.onload = () => resolve(reader.result)
            reader.onerror = reject
            reader.readAsDataURL(img)
        })
    }

    $(document).ready(() => {
        $("#searchArea").on("input", function() {
            let searchText = $("#searchArea").val()
            let token = "<%= mapboxtoken %>"
            console.log($("#searchArea").val())
            $.ajax({
                method: "get",
                url: `https://api.mapbox.com/search/searchbox/v1/suggest?q=${searchText}&access_token=${token}&session_token=XQRVteWe`,
                data: {},
                success: function(res) {
                    console.log(res)
                },
                error: function(err) {
                    console.log(err)
                }
            })
        })
        $('#spotImages').on('change', function() {
            let images = document.getElementById('spotImages')
            let totalSize = 0
            for (let x = 0; x < images.files.length; x++) {
                console.log(images.files[x].size)
                totalSize = totalSize + images.files[x].size
            }
            sizeInMB = totalSize / 1000000
            console.log("total size", sizeInMB.toFixed(2))
            $('#fileSizeSpan').html(sizeInMB.toFixed(2))
        })
        $('#addSpotForm').submit(function(e) {
            e.preventDefault()
            $("#spinnerContainer").css("display", "block")
            let images = document.getElementById("spotImages")
            // console.log(images.files)
            let image64Promises = []
            for (let x = 0; x < images.files.length; x++) {
                image64Promises.push(filesToBase64(images.files[x]))
            }

            Promise.all(image64Promises)
            .then(fileResults => {
                console.log(fileResults)
                let sendData = {
                    description: $('#description').val(),
                    spottype: $('#spottype').val(),
                    lng: markerCoordinates[0],
                    lat: markerCoordinates[1],
                    spotimages: fileResults
                }

                $.ajax({
                    method: "post",
                    url: "/addspot",
                    data: sendData,
                    success: function(res) {
                        $("#spinnerContainer").css("display", "none")
                        console.log("successful request", res)
                        addNewAlert(res.status, res.message)
                        map.easeTo({
                            center: [36.8219, -1.2921],
                            zoom: 10
                        })
                        addSpotForm.style.display = "none"
                        spotInformation.style.display = "block"
                        cancelNewSpotButton.style.display = "none"
                        addNewSpotButton.style.display = "block"
                        addSpotMarker.remove()
                        addSpotForm.style.display = "none"
                        window.location.replace(`/map?spot=${res.newSpot}`)

                    },
                    error: function(error) {
                        $("#spinnerContainer").css("display", "none")
                        console.log("error on request", error)
                    }
                })
            })
            .catch(err => {
                console.log(err)
            })
        })

    })
</script>
</html>