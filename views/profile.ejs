<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <%- include('templates/nav.ejs') %>
    <%- include('templates/alert.ejs') %>
    <%- include('templates/theme.ejs') %>
    <div class="profile-div">
        <div class="profile-side">
            <div class="profile-info-div" style="display: flex; flex-direction: column; align-items: start;">
                <div class="profile-image-container">
                    <div class="profile-settings-picture" style="background-image: url('<%= user.profileImage %>');" id="profilePicture">
                        <!-- <img src="/images/defaultProfile.jpg" alt="" style="width: 100%; aspect-ratio: 1 / 1;"> -->
                    </div>
                    <div class="edit-profile-image" id="editProfileImage">
                        <p style="margin: 0; font-size: 1em; font-weight: bold;">+</p>
                    </div>
                    <input type="file" accept="image" name="profilePicture" id="profilePictureInput" style="display: none;">
                </div>
                <p class="profile-title">Details</p>
                <div class="underline"></div>

                <p class="profile-detail-title">Name</p>
                <p class="profile-detail-info">Test name</p>

                <p class="profile-detail-title">Email</p>
                <p class="profile-detail-info">testemail@gmail.com</p>

                <div style="display: flex; align-items: center; gap: 5px; margin-top: 1em;">
                    <p>Verified</p>
                    <div class="verified-tick-div">
                        <img src="/logos/checkLight.png" alt="tick" style="height: 9px;">
                    </div>
                </div>
            </div>
        </div>
        <div class="profile-divider"></div>
        <div class="profile-main">
            <div class="profile-info-div">
                <p class="profile-title">Settings</p>
                <div class="underline"></div>

                <div class="profile-pill-outer">
                    <div class="profile-pill-title">Two factor Authentication</div>
                    <div class="profile-pill-div" id="twoFactorAuthPill">
                        <div class="profile-pill-circle" id="twoFactorAuthPillCircle"></div>
                    </div>
                    <input type="hidden" value="<%= user.settings.twoFactorAuth %>" id="twoFactorAuthPillValue">
                </div>
                <div class="profile-pill-outer">
                    <div class="profile-pill-title">Dark mode</div>
                    <div class="profile-pill-div" id="darkModePill">
                        <div class="profile-pill-circle" id="darkModePillCircle"></div>
                    </div>
                    <input type="hidden" value="<%= user.settings.darkMode %>" id="darkModePillValue">
                </div>
                <div class="profile-pill-outer">
                    <div class="profile-pill-title">Dark map</div>
                    <div class="profile-pill-div" id="darkMapPill">
                        <div class="profile-pill-circle" id="darkMapPillCircle"></div>
                    </div>
                    <input type="hidden" value="<%= user.settings.darkMap %>" id="darkMapPillValue">
                </div>
            </div>
            <div class="profile-info-div">
                <p class="profile-title">Spots Content</p>
                <div class="underline"></div>
                <button class="base-button" style="margin-right: 1em;">Liked spots</button>
                <button class="base-button">My Uploads</button>
            </div>
        </div>
    </div>
    <div class="profile-image-modal-outer" id="profileImageModalOuter">
        <div class="profile-image-modal-container" id="profileImageModalContainer">
            <img src="./logos/closelight.png" alt="close menu" class="close-menu2" onclick="hideProfileImageModal()">
            <p style="align-self: center; font-weight: bold;">Preview</p>

            <div class="profile-image-container" style="width: 50%;">
                <div class="profile-settings-picture" style="background-image: url('/images/defaultProfile2.png'); width: 100%;" id="profilePicturePreview">
                </div>
                <input type="file" accept="image" name="profilePicture" id="profilePictureInput" style="display: none;">
            </div>
            <button class="default-button" style="justify-self: flex-end;" id="confirmProfileImageUpdate">CONFIRM</button>
        </div>
    </div>
</body>
<script>
    let user = JSON.parse('<%- JSON.stringify(user)%>')
    let twoFactorAuthPill = document.getElementById("twoFactorAuthPill")
    let darkModePill = document.getElementById("darkModePill")
    let darkMapPill = document.getElementById("darkMapPill")

    let twoFactorAuthPillCircle = document.getElementById("twoFactorAuthPillCircle")
    let darkModePillCircle = document.getElementById("darkModePillCircle")
    let darkMapPillCircle = document.getElementById("darkMapPillCircle")

    function updateSettingsDisplay() {
        twoFactorAuthPill.classList.add(user.settings.twoFactorAuth ? "pill-on" : "pill-off")
        darkModePill.classList.add(user.settings.darkMode ? "pill-on" : "pill-off")
        darkMapPill.classList.add(user.settings.darkMap ? "pill-on" : "pill-off")

        twoFactorAuthPillCircle.classList.add(user.settings.twoFactorAuth ? "pill-circle-on" : "pill-circle-off")
        darkModePillCircle.classList.add(user.settings.darkMode ? "pill-circle-on" : "pill-circle-off")
        darkMapPillCircle.classList.add(user.settings.darkMap ? "pill-circle-on" : "pill-circle-off")
    }
    updateSettingsDisplay()

    function filesToBase64(img) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader
            reader.onload = () => resolve(reader.result)
            reader.onerror = reject
            reader.readAsDataURL(img)
        })
    }

    let profilePictureInput = document.getElementById("profilePictureInput")
    let profilePreview = ""
    document.getElementById("editProfileImage").addEventListener("click", function() {
        profilePictureInput.click()
    })

    profilePictureInput.addEventListener("change", function() {
        console.log(profilePictureInput.files[0].size)
        filesToBase64(profilePictureInput.files[0])
        .then(fileRes => {
            // console.log(fileRes)
            profilePreview = fileRes
            let prev = document.getElementById("profilePicturePreview")
            prev.style.backgroundImage = `url("${profilePreview}")`
            openProfileImageModal()
        })
        .catch(error => {
            console.log(error)
        })
    })

    // document.getElementById("confirmProfileImageUpdate").addEventListener("click", function() {
    //     fetch('/updateProfileImage', {
    //         method: "POST",
    //         headers: {
    //             // "Accept": "application/json",
    //             "Content-Type": "application/json"
    //         },
    //         body: JSON.stringify({
    //             profileImage: profilePreview
    //         })
    //     })
    //     .then(res => {
    //         console.log(res)
    //     })
    //     .catch(error => {
    //         console.log(error)
    //     })
    // })

    function openProfileImageModal() {
        let profileImageModalOuter = document.getElementById("profileImageModalOuter")
        let profileImageModalContainer = document.getElementById("profileImageModalContainer")
        profileImageModalOuter.style.opacity = 1
        profileImageModalContainer.style.transform = "translateY(0)"
        profileImageModalOuter.style.pointerEvents = "auto"
    }

    function hideProfileImageModal() {
        let profileImageModalOuter = document.getElementById("profileImageModalOuter")
        let profileImageModalContainer = document.getElementById("profileImageModalContainer")
        profileImageModalOuter.style.opacity = 0
        profileImageModalContainer.style.transform = "translateY(-20%)"
        profileImageModalOuter.style.pointerEvents = "none"
    }

    async function retrieveUploads() {
        await fetch("/getUserSpots", {
            method: "GET"
        })
        .then(async res => {
            let resData = await res.json()
            console.log(resData.myUploads)
        })
    }
    retrieveUploads()

    $(document).ready(function () {

        $(".profile-pill-div").on("click", function() {
            $(this).toggleClass("pill-on")
            let pillID = $(this).attr("id") + "Circle"
            let pillVal = $(this).attr("id") + "Value"
            $(`#${pillID}`).toggleClass("pill-circle-on")
            if ($(`#${pillVal}`).val() == "true") {
                $(`#${pillVal}`).val("false")
            } else {
                $(`#${pillVal}`).val("true")
            }
            console.log($(`#${pillVal}`).val())
            $.ajax({
                url: "updateProfile",
                method: "post",
                data: {
                    twoFactorAuth: $("#twoFactorAuthPillValue").val(),
                    darkMode: $("#darkModePillValue").val(),
                    darkMap: $("#darkMapPillValue").val(),
                },
                success: function(res) {
                    console.log(res)
                    if (res.status === "SUCCESS") {
                        if ($("#darkModePillValue").val() === "true") {
                            document.body.classList.add("dark-mode")
                            document.body.classList.remove("light-mode")
                        } else if ($("#darkModePillValue").val() === "false") {
                            document.body.classList.remove("dark-mode")
                            document.body.classList.add("light-mode")
                        } else {
                            document.body.classList.remove("dark-mode")
                            document.body.classList.remove("light-mode")
                        }
                        addNewAlert(res.status, res.message)
                    } else if (res.status === "ERROR") {
                        addNewAlert(res.status, res.message)
                    }
                },
                error: function(error) {
                    console.log(error)
                }
            })
        })

        $("#confirmProfileImageUpdate").on("click", function() {
            $.ajax({
                url: "/updateProfileImage",
                method: "post",
                data: {
                    profileImage: profilePreview
                },
                success: function(res) {
                    console.log(res)
                    $("#profilePicture").css('background-image', `url('${profilePreview}')`)
                    hideProfileImageModal()
                    addNewAlert(res.status, res.message)
                },
                error: function(error) {
                    console.log(error)
                }
            })
        })
    })
</script>
</html>