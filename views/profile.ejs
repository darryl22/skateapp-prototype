    $(document).ready(function () {

        $(".profile-pill-div").on("click", function() {
            $(this).toggleClass("pill-on")
            let pillID = $(this).attr("id") + "Circle"
            let pillVal = $(this).attr("id") + "Value"
            $(`#${pillID}`).toggleClass("pill-circle-on")
            if ($(`#${pillVal}`).val() == "true") {
                $(`#${pillVal}`).val("false")
            } else {
                $(`#${pillVal}`).val("true")
            }
            console.log($(`#${pillVal}`).val())
            $.ajax({
                url: "updateProfile",
                method: "post",
                data: {
                    twoFactorAuth: $("#twoFactorAuthPillValue").val(),
                    darkMode: $("#darkModePillValue").val(),
                    darkMap: $("#darkMapPillValue").val(),
                },
                success: function(res) {
                    console.log(res)
                    if (res.status === "SUCCESS") {
                        if ($("#darkModePillValue").val() === "true") {
                            document.body.classList.add("dark-mode")
                            document.body.classList.remove("light-mode")
                        } else if ($("#darkModePillValue").val() === "false") {
                            document.body.classList.remove("dark-mode")
                            document.body.classList.add("light-mode")
                        } else {
                            document.body.classList.remove("dark-mode")
                            document.body.classList.remove("light-mode")
                        }
                        addNewAlert(res.status, res.message)
                    } else if (res.status === "ERROR") {
                        addNewAlert(res.status, res.message)
                    }
                },
                error: function(error) {
                    console.log(error)
                }
            })
        })

        $("#confirmProfileImageUpdate").on("click", function() {
            $.ajax({
                url: "/updateProfileImage",
                method: "post",
                data: {
                    profileImage: profilePreview
                },
                success: function(res) {
                    console.log(res)
                    $("#profilePicture").css('background-image', `url('${profilePreview}')`)
                    hideProfileImageModal()
                    addNewAlert(res.status, res.message)
                },
                error: function(error) {
                    console.log(error)
                }
            })
        })
    })
