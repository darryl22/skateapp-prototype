    function updateModalImages(id, images, action="reset") {
        let editPicturesDiv = document.getElementById(`editPicturesDiv-${id}`)
        let spotPicturesCarousel = document.getElementById(`spotPicturesCarousel-${id}`).querySelectorAll(".swiper-wrapper")[0]
        let imageNodes = ''
        let carouselNodes = ''
        let imageList = new Map()

        for (let x = 0; x < images.length; x++) {
            if (action === "reset") {
                imageList.set(`list-${images[x]._id}`, {
                    spotId: images[x].spotId,
                    imageId: images[x]._id,
                    imageUrl: images[x].imageUrl,
                    position: images[x].position,
                    isSelected: false,
                    newPosition: false
                })
            } else if (action === "addnew") {
                selectedImages.get(`spot-${id}`).set(`list-${images[x]._id}`, {
                    spotId: images[x].spotId,
                    imageId: images[x]._id,
                    imageUrl: images[x].imageUrl,
                    position: images[x].position,
                    isSelected: false,
                    newPosition: false
                })
            }
            // <img src="/logos/checkLight.png" alt="" style="width: 80%;"> check green
            let image = `<div class="edit-pictures-item" style="background-image: url('${images[x].imageUrl}');" id="editItem${images[x]._id}" data-picture-index="${images[x].position}" data-id="${id}" data-imageid="${images[x]._id}" data-imageidoriginal="${images[x]._id}">
                <div class="edit-pictures-check hide-check">
                    <p style="margin: 0;">X</p>
                </div>
                <div class="edit-check-circle"></div>
            </div>`

            let cNode = `<div class="swiper-slide">
                <div class="carousel-image" style="background-image: url('${images[x].imageUrl}'); background-size: contain;"></div>
            </div>`

            imageNodes = imageNodes + image
            carouselNodes = carouselNodes + cNode
        }
        if (action === "reset") {
            editPicturesDiv.replaceChildren()
            spotPicturesCarousel.replaceChildren()
            selectedImages.set(`spot-${id}`, imageList)
        }
        console.log("action is", action)
        console.log("spot images are", selectedImages)
        editPicturesDiv.insertAdjacentHTML("beforeend",imageNodes)
        spotPicturesCarousel.insertAdjacentHTML("beforeend",carouselNodes)
        const swiper = new Swiper(`.swiper${id}`, {
            direction: 'horizontal',
            loop: true,
            pagination: {
                el: '.swiper-pagination',
            },
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            scrollbar: {
                el: '.swiper-scrollbar',
            },
            obsever: true,
            observeParents: true
        });
        updateModalListeners()
        // swiper.appendSlide(`<div class="swiper-slide">
        //     <div class="carousel-image" style="background-image: url('/images/loading.png'); background-size: contain;"></div>
        // </div>`)
    }

    function clearSelections(id) {
        let editPicturesDiv = document.getElementById(`editPicturesDiv-${id}`)
        document.getElementById(`confirmEditImagesButton-${id}`).classList.add("hidden")
        // let positionReset = 0
        editPicturesDiv.querySelectorAll(".edit-pictures-item").forEach(elm => {
            console.log("picture index", elm.getAttribute("data-picture-index"))
            let check = elm.querySelectorAll(".edit-pictures-check")[0]
            // let imageId = elm.getAttribute("data-imageid")
            let imageId = elm.getAttribute("data-imageidoriginal")
            elm.setAttribute("data-imageid", imageId)
            check.classList.add("hide-check")
            let currentImage = selectedImages.get(`spot-${id}`).get(`list-${imageId}`)
            if(currentImage.newPosition) {
                elm.style.backgroundImage = `url("${currentImage.imageUrl}")`
            }
            console.log("new index", currentImage.position)
            selectedImages.get(`spot-${id}`).set(`list-${imageId}`, {
                ...currentImage,
                isSelected: false,
                newPosition: false,
                position: parseInt(elm.getAttribute("data-picture-index"))
            })
        })
    }

