    <title>Skatespot App</title>
    <link rel="stylesheet" href="/index.css">
    <style>
        .nav-div{
            box-shadow: none;
        }

        .swiper {
            width: 100%;
            height: 50vh;
        }

        body{
            overflow: hidden;
